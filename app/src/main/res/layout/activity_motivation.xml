<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MotivationActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Daily Motivation "
            android:background="@drawable/shape"
            android:padding="10dp"
            android:textSize="35sp"
            android:textAlignment="center"
            android:textStyle="bold"
            android:fontFamily="@font/agbalumo"
            android:textColor="#F2F2EE"/>

        <!-- 🔹 DAILY QUOTE CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFF3E0"
            android:layout_marginTop="12dp"
            android:padding="14dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💬 Today's Quote"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#E65100"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="“Small steps every day lead to big results.”"
                android:textSize="16sp"
                android:textColor="#444444"
                android:paddingTop="6dp"/>
        </LinearLayout>

        <!-- 🔹 SUCCESS CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#E8F5E9"
            android:layout_marginTop="12dp"
            android:padding="14dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚀 Success Mindset"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1B5E20"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Discipline beats motivation. Stay consistent even when you don’t feel like it."
                android:textColor="#444444"
                android:paddingTop="6dp"/>
        </LinearLayout>

        <!-- 🔹 CONFIDENCE CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#E3F2FD"
            android:layout_marginTop="12dp"
            android:padding="14dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💪 Build Confidence"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#0D47A1"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Believe in yourself. You are capable of more than you think."
                android:textColor="#444444"
                android:paddingTop="6dp"/>
        </LinearLayout>

        <!-- 🔹 FOCUS CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#F3E5F5"
            android:layout_marginTop="12dp"
            android:padding="14dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎯 Stay Focused"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#6A1B9A"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Remove distractions. Focus on your goals and take action daily."
                android:textColor="#444444"
                android:paddingTop="6dp"/>
        </LinearLayout>

        <!-- 🔹 DAILY REMINDER CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#E0F7FA"
            android:layout_marginTop="12dp"
            android:padding="14dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏰ Daily Reminder"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#006064"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your future is created by what you do today, not tomorrow."
                android:textColor="#444444"
                android:paddingTop="6dp"/>
        </LinearLayout>


    </LinearLayout>

</ScrollView>