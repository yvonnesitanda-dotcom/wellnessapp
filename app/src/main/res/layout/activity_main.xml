<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="#F3F8F8"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!--Below is a linear layout that holds our views -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

<!--Below is a text view-->

        <!--Below is an Image view-->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/agbalumo"
            android:text="Health And Wellness App"
            android:textAlignment="center"
            android:textColor="#F4F2EF"
            android:textSize="45sp"
            android:textStyle="bold"
            android:background="@drawable/shape"
            android:padding="10dp"/>

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="196dp"
            android:src="@drawable/image1" />


<!--Below is button number 1-->


        <Button

            android:id="@+id/Healthy_recipes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:backgroundTint="#FF5722"
            android:text="Healthy Recipes"
            android:textSize="20sp" />

        <!--   Below is button 2-->

        <Button


            android:id="@+id/Nutrition_advice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:backgroundTint="#FF5722"
            android:text="Nutrition Advice "
            android:textSize="20sp" />

        <!--   Below is button 3-->
        <Button


            android:id="@+id/Meditation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:backgroundTint="#FF5722"
            android:text="Meditation "
            android:textSize="20sp" />

        <!--   Below is button 4-->
        <Button


            android:id="@+id/Hydration_alert"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:backgroundTint="#FF5722"
            android:text="Hydration Alert"
            android:textSize="20sp" />

        <!--   Below is button 5-->
        <Button


            android:id="@+id/Start_exercise"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:backgroundTint="#FF5722"
            android:text="Start Exercise"
            android:textSize="20sp" />

        <!--   Below is button 7-->
        <Button


            android:id="@+id/Daily_Motivation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:backgroundTint="#FF5722"
            android:text="Daily Motivation "
            android:textSize="20sp" />

        <!--   Below is button 8-->
        <Button


            android:id="@+id/Weekly_goals"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:backgroundTint="#FF5722"
            android:text="Weekly Goals"
            android:textSize="20sp" />

        <!--   Below is button 9-->
        <Button


            android:id="@+id/Check_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:backgroundTint="#FF5722"
            android:text="Check Progress"
            android:textSize="20sp" />




    </LinearLayout>


</ScrollView>