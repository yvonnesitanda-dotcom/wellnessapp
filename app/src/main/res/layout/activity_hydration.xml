<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".HydrationActivty">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hydration and Water Intake "
            android:background="@drawable/shape"
            android:padding="10dp"
            android:textSize="35sp"
            android:textAlignment="center"
            android:textStyle="bold"
            android:fontFamily="@font/agbalumo"
            android:textColor="#EDEDEA"/>

        <!-- 🔹 WATER GOAL CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#E3F2FD"
            android:layout_marginTop="12dp"
            android:padding="14dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💧 Daily Water Goal"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#0D47A1"/>

            <ProgressBar
                android:id="@+id/waterProgress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="20dp"
                android:progress="60"
                android:max="100"
                android:progressTint="#2196F3"
                android:progressBackgroundTint="#BBDEFB"
                android:layout_marginTop="10dp"/>
        </LinearLayout>

        <!-- 🔹 BENEFITS CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#E8F5E9"
            android:layout_marginTop="12dp"
            android:padding="14dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌿 Benefits of Drinking Water"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1B5E20"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="• Improves energy levels\n• Keeps skin healthy\n• Helps digestion\n• Flushes toxins\n• Improves focus"
                android:textColor="#444444"
                android:paddingTop="6dp"/>
        </LinearLayout>

        <!-- 🔹 REMINDER CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFF3E0"
            android:layout_marginTop="12dp"
            android:padding="14dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏰ Hydration Reminder"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#E65100"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Drink at least 8 glasses of water daily. Start your morning with a glass of water."
                android:textColor="#444444"
                android:paddingTop="6dp"/>
        </LinearLayout>

        <!-- 🔹 TIP CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#F3E5F5"
            android:layout_marginTop="12dp"
            android:padding="14dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💡 Hydration Tip"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#6A1B9A"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Carry a water bottle with you and sip throughout the day instead of drinking all at once."
                android:textColor="#444444"
                android:paddingTop="6dp"/>
        </LinearLayout>
    </LinearLayout>

</ScrollView>