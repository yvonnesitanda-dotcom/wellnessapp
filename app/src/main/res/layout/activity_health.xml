<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".HealthActivity"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp">

        <!-- HEADER -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/shape"
            android:fontFamily="@font/agbalumo"
            android:padding="14dp"
            android:text="Health Recipes"
            android:textAlignment="center"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:textStyle="bold" />

        <!-- IMAGE -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="10dp"
            android:scaleType="centerCrop"
            android:src="@drawable/image1"
            android:background="#FFFFFF"
            android:elevation="4dp"/>

        <!-- CARD 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFF3E0"
            android:layout_marginTop="12dp"
            android:padding="14dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🍎 Fruit Salad"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#E65100"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="A mix of fresh fruits like bananas, apples, and oranges."
                android:textColor="#444444"
                android:paddingTop="4dp"/>
        </LinearLayout>

        <!-- CARD 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#E3F2FD"
            android:layout_marginTop="10dp"
            android:padding="14dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🍗 Grilled Chicken"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#0D47A1"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Low-fat grilled chicken served with vegetables."
                android:textColor="#444444"
                android:paddingTop="4dp"/>
        </LinearLayout>

        <!-- CARD 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#E8F5E9"
            android:layout_marginTop="10dp"
            android:padding="14dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🥦 Vegetable Stir Fry"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1B5E20"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Carrots, broccoli, and peppers cooked lightly."
                android:textColor="#444444"
                android:paddingTop="4dp"/>
        </LinearLayout>

        <!-- CARD 4 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#F3E5F5"
            android:layout_marginTop="10dp"
            android:padding="14dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🥣 Oatmeal Breakfast"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#6A1B9A"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Oats with milk and fruits."
                android:textColor="#444444"
                android:paddingTop="4dp"/>
        </LinearLayout>

        <!-- CARD 5 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFDE7"
            android:layout_marginTop="10dp"
            android:padding="14dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🥑 Avocado Toast"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#F57F17"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Whole grain bread topped with avocado."
                android:textColor="#444444"
                android:paddingTop="4dp"/>
        </LinearLayout>

        <!-- CARD 6 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#E0F7FA"
            android:layout_marginTop="10dp"
            android:padding="14dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🥚 Boiled Eggs"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#006064"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rich in protein and easy to prepare."
                android:textColor="#444444"
                android:paddingTop="4dp"/>
        </LinearLayout>

        <!-- CARD 7 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FCE4EC"
            android:layout_marginTop="10dp"
            android:padding="14dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🍓 Smoothie Bowl"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#880E4F"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Blended fruits with yogurt and nuts."
                android:textColor="#444444"
                android:paddingTop="4dp"/>
        </LinearLayout>

        <!-- CARD 8 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#E8EAF6"
            android:layout_marginTop="10dp"
            android:padding="14dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🍚 Brown Rice and Beans"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1A237E"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Healthy and full of fiber."
                android:textColor="#444444"
                android:paddingTop="4dp"/>
        </LinearLayout>

        <!-- CARD 9 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFF8E1"
            android:layout_marginTop="10dp"
            android:padding="14dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🐟 Baked Fish"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FF6F00"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fish baked with lemon and spices."
                android:textColor="#444444"
                android:paddingTop="4dp"/>
        </LinearLayout>

        <!-- CARD 10 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#EDE7F6"
            android:layout_marginTop="10dp"
            android:padding="14dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🍯 Greek Yogurt and Honey"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#4527A0"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Good for digestion and very nutritious."
                android:textColor="#444444"
                android:paddingTop="4dp"/>
        </LinearLayout>

    </LinearLayout>

</ScrollView>